
{
  "entities": {
    "AthleteProfile": {
      "title": "Perfil do Atleta",
      "description": "Dados completos do atleta incluindo fisiologia, nutrição e força.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerUid": { "type": "string", "description": "UID do Treinador dono do perfil" },
        "athleteEmail": { "type": "string", "description": "E-mail do Google do atleta para acesso vinculado" },
        "avatarUrl": { "type": "string" },
        "location": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "currentWeight": { "type": "number" },
        "height": { "type": "number" },
        "restingHr": { "type": "number" },
        "vo2Max": { "type": "number" },
        "thresholdPace": { "type": "string" },
        "thresholdHr": { "type": "number" },
        "raceName": { "type": "string" },
        "raceDistance": { "type": "string" },
        "raceDate": { "type": "string", "format": "date" },
        "raceGoal": { "type": "string" },
        "targetPace": { "type": "string" },
        "targetTime": { "type": "string" },
        "trainingDays": { "type": "array", "items": { "type": "string" } },
        "longRunDay": { "type": "string" },
        "weeklyMileageGoal": { "type": "number" },
        "planGenerationType": { "type": "string", "enum": ["full", "blocks"] },
        "experienceLevel": { "type": "string", "enum": ["run_walk", "beginner", "intermediate", "advanced"] },
        "trainingHistory": { "type": "string" },
        "trainingPlan": { "type": "object", "description": "Plano de treino atual do atleta" },
        "dietPreferences": { "$ref": "#/backend/entities/DietPreferences" },
        "strengthPreferences": { "$ref": "#/backend/entities/StrengthPreferences" }
      }
    },
    "DietPreferences": {
      "title": "Preferências Dieta",
      "type": "object",
      "properties": {
        "aestheticGoal": { "type": "string", "enum": ["performance", "cutting", "bulking", "recomp"] },
        "trainingTiming": { "type": "string", "enum": ["jejum", "manha", "meio-dia", "tarde", "noite"] },
        "mealCount": { "type": "number" },
        "supplements": { "type": "string" },
        "allergies": { "type": "string" }
      }
    },
    "StrengthPreferences": {
      "title": "Preferências Força",
      "type": "object",
      "properties": {
        "splitPreference": { "type": "string", "enum": ["full_body", "upper_lower", "ppl"] },
        "objective": { "type": "string", "enum": ["strength", "hypertrophy", "performance", "endurance"] },
        "legDay": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/user_data/{userId}": {
      "schema": "object",
      "description": "Dados do usuário e seu perfil de atleta sincronizado."
    }
  }
}
